<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KineFlow Pro - Gestión Médica</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .modal-overlay { background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px); }
        .active-tab { background-color: #2563eb; color: white; box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.2); }
        .emerald-card { background-color: #10b981; border-color: #10b981; color: white; }
        
        /* Screenshot showcase styles */
        .app-showcase {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 50%, #f5f0ff 100%);
            min-height: 100vh;
        }
        .screenshot-frame {
            border-radius: 2.5rem;
            overflow: hidden;
            box-shadow: 0 40px 80px -20px rgba(37, 99, 235, 0.2), 0 20px 40px -10px rgba(0,0,0,0.1);
            border: 6px solid white;
        }
        .screenshot-frame img {
            width: 100%;
            display: block;
        }
        .feature-badge {
            background: white;
            border-radius: 1rem;
            padding: 0.75rem 1.25rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
    </style>
</head>
<body>

<!-- ============================================================ -->
<!--  APP SHOWCASE SECTION (referencias visuales de las imágenes) -->
<!-- ============================================================ -->
<section class="app-showcase py-16 px-4">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-16">
            <div class="inline-flex items-center gap-2 bg-blue-50 text-blue-600 px-4 py-2 rounded-full text-xs font-black uppercase tracking-widest mb-6">
                <span>⚡</span> KineFlow Pro
            </div>
            <h1 class="text-5xl font-black text-slate-900 leading-tight mb-4">
                Gestión Clínica<br><span class="text-blue-600">para Kinesiólogos</span>
            </h1>
            <p class="text-slate-500 text-lg font-medium max-w-xl mx-auto">
                Plataforma completa para gestión de pacientes, sesiones de entrenamiento y biblioteca de ejercicios terapéuticos.
            </p>
        </div>

        <!-- Screenshots Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
            <div class="flex flex-col items-center gap-4">
                <div class="screenshot-frame w-full max-w-[200px]">
                    <img src="data:image/png;base64," alt="Vista Entrenar">
                </div>
                <div class="feature-badge text-sm font-bold text-slate-700">
                    <span>🏋️</span> Sesiones
                </div>
            </div>
            <div class="flex flex-col items-center gap-4">
                <div class="screenshot-frame w-full max-w-[200px]">
                    <img src="data:image/png;base64," alt="Biblioteca Clínica">
                </div>
                <div class="feature-badge text-sm font-bold text-slate-700">
                    <span>📚</span> Biblioteca
                </div>
            </div>
            <div class="flex flex-col items-center gap-4">
                <div class="screenshot-frame w-full max-w-[200px]">
                    <img src="data:image/png;base64," alt="Perfil Paciente">
                </div>
                <div class="feature-badge text-sm font-bold text-slate-700">
                    <span>👤</span> Pacientes
                </div>
            </div>
            <div class="flex flex-col items-center gap-4">
                <div class="screenshot-frame w-full max-w-[200px]">
                    <img src="data:image/png;base64," alt="Historial Sesiones">
                </div>
                <div class="feature-badge text-sm font-bold text-slate-700">
                    <span>📋</span> Historial
                </div>
            </div>
        </div>

        <div class="text-center">
            <button onclick="document.getElementById('app-section').scrollIntoView({behavior:'smooth'})" 
                class="bg-blue-600 text-white px-10 py-5 rounded-2xl font-black text-lg shadow-xl shadow-blue-200 hover:bg-blue-700 active:scale-95 transition-all">
                Abrir Aplicación ↓
            </button>
        </div>
    </div>
</section>

<div id="app-section">
<!-- ============================================================ -->
<!--  APP PRINCIPAL                                               -->
<!-- ============================================================ -->

    <!-- Indicador de Sincronización -->
    <div id="syncIndicator" class="fixed top-4 right-4 z-[60] flex items-center gap-2 bg-white/90 backdrop-blur px-4 py-2 rounded-full border border-slate-200 shadow-sm transition-all duration-300">
        <i id="cloudIcon" data-lucide="cloud" class="w-4 h-4 text-emerald-500"></i>
        <span id="syncText" class="text-[10px] font-bold uppercase text-slate-400 tracking-widest">Sincronizado</span>
    </div>

    <!-- Navegación Inferior -->
    <nav class="fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-slate-200 flex justify-around p-4 z-50 shadow-lg">
        <button id="nav-workout" onclick="setView('workout')" class="nav-btn flex flex-col items-center gap-1.5 px-5 py-1 transition-all">
            <i data-lucide="dumbbell"></i><span class="text-[10px] font-bold">Entrenar</span>
        </button>
        <button id="nav-patients" onclick="setView('patients')" class="nav-btn flex flex-col items-center gap-1.5 px-5 py-1 text-slate-300 transition-all">
            <i data-lucide="users"></i><span class="text-[10px] font-bold">Pacientes</span>
        </button>
        <button id="nav-catalog" onclick="setView('catalog')" class="nav-btn flex flex-col items-center gap-1.5 px-5 py-1 text-slate-300 transition-all">
            <i data-lucide="layers"></i><span class="text-[10px] font-bold">Biblioteca</span>
        </button>
        <button id="nav-history" onclick="setView('history')" class="nav-btn flex flex-col items-center gap-1.5 px-5 py-1 text-slate-300 transition-all">
            <i data-lucide="history"></i><span class="text-[10px] font-bold">Logs</span>
        </button>
    </nav>

    <!-- Contenedor Principal -->
    <main id="mainContent" class="max-w-2xl mx-auto p-4 pt-6 pb-32 bg-slate-50 min-h-screen">
        <div class="flex items-center justify-center h-64">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
        </div>
    </main>

    <!-- Modales -->
    <div id="modalContainer" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center p-4 modal-overlay"></div>

</div>

    <!-- Firebase SDK -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, doc, setDoc, onSnapshot, addDoc, deleteDoc, updateDoc, getDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'kineflow-html-v15';
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);

        let state = {
            user: null,
            view: 'workout',
            activeIdx: 0,
            slots: Array(6).fill(null).map((_, i) => ({
                id: i + 1,
                patientName: "",
                strength: [],
                time: 0,
                isActive: false,
                completed: {},
                mobilityCollapsed: true
            })),
            patients: [],
            history: [],
            catalog: { categories: [] },
            syncing: false,
            search: { library: '', picker: '' },
            isEditingPatient: null,
            isViewingHistory: null,
            isEditingHistory: null
        };

        const INITIAL_CATALOG = {
          categories: [
            { id: 'cat_mob', name: "MOVILIDAD Y ACTIVACIÓN ESCAPULAR", exercises: [
                { name: "Elongación fascia con control respiratorio", level: "Principiante" },
                { name: "Elongación psoas dinámica", level: "Principiante" },
                { name: "Estocada con rotación contraria con pesa rusa", level: "Intermedio" },
                { name: "Postura caballero manos juntas movilidad escapular", level: "Principiante" },
                { name: "Spiderman (toco tobillos rotando)", level: "Intermedio" },
                { name: "Tocar rodillas en rotación", level: "Principiante" },
                { name: "Espinales + movilidad escapular alternada", level: "Principiante" },
                { name: "Retracción escapular con banda en codos", level: "Principiante" },
                { name: "Rotación externa de hombro con banda", level: "Principiante" }
            ]},
            { id: 'cat_core', name: "CORE / ESCÁPULA / ESTABILIDAD", exercises: [
                { name: "Superman", level: "Principiante" },
                { name: "Plancha alta con transferencia de mancuerna", level: "Avanzado" },
                { name: "Plancha con apertura lateral y diagonal con banda", level: "Avanzado" },
                { name: "Plancha baja con rotación escapular con mancuerna", level: "Avanzado" },
                { name: "Plancha alta a baja con rodillas al pecho", level: "Avanzado" },
                { name: "Rotaciones de tronco en abdominal con pesa rusa", level: "Intermedio" },
                { name: "Bicho muerto (y sus variantes)", level: "Principiante" },
                { name: "Rotaciones con banda arrodillado (pall of press)", level: "Intermedio" },
                { name: "Plancha lateral con mancuerna y flexión de rodilla con banda", level: "Avanzado" },
                { name: "Abductores en plancha lateral con disco", level: "Intermedio" },
                { name: "Vitalización en posición de caballero con kettlebell invertida", level: "Intermedio" },
                { name: "Plancha y pies (adentro, afuera, arriba y abajo)", level: "Avanzado" },
                { name: "Plancha y rodillas al medio y afuera", level: "Intermedio" },
                { name: "Peso muerto remo (transferencia potencia)", level: "Intermedio" },
                { name: "Aductores con banco en plancha lateral (puente copenhague)", level: "Avanzado" }
            ]},
            { id: 'cat_posterior', name: "MOVILIDAD CADENA POSTERIOR", exercises: [
                { name: "Bisagra de cadera con estiramiento posterior", level: "Principiante" },
                { name: "Elongación Fascia (aguantando respiración)", level: "Principiante" },
                { name: "Elongación de columna en cruz", level: "Principiante" }
            ]},
            { id: 'cat_inf', name: "FUERZA TREN INFERIOR / POTENCIA", exercises: [
                { name: "Saltos laterales alternados sobre cajón", level: "Avanzado" },
                { name: "Peso muerto con barra", level: "Intermedio" },
                { name: "Búlgaras con vuelos laterales", level: "Avanzado" },
                { name: "Sentadilla tocando tobillos alternados", level: "Principiante" },
                { name: "Tocar pie con mano contraria dinámico (parado)", level: "Principiante" },
                { name: "Desplazamiento lateral con banda sentadilla", level: "Intermedio" },
                { name: "Sentadilla con pesa rusa y banda en los pies", level: "Intermedio" },
                { name: "Sentadillas en TRX", level: "Principiante" },
                { name: "Subida al cajón con mancuernas + press hombro", level: "Avanzado" },
                { name: "Subida al cajón con pesa rusa", level: "Intermedio" }
            ]},
            { id: 'cat_sup', name: "FUERZA TREN SUPERIOR", exercises: [
                { name: "Dominadas", level: "Avanzado" },
                { name: "Dominadas con peso", level: "Avanzado" },
                { name: "Aperturas de pecho en banco o pelota", level: "Principiante" },
                { name: "Flexiones con remo", level: "Intermedio" },
                { name: "Flexiones de brazos con flexión de rodilla explosiva", level: "Avanzado" },
                { name: "Remo con banda elástica", level: "Principiante" },
                { name: "Pecho/Remo en TRX", level: "Intermedio" },
                { name: "Press de hombro con banda en la panza", level: "Intermedio" }
            ]},
            { id: 'cat_int', name: "FUERZA INTEGRADA (PIERNAS + BRAZOS)", exercises: [
                { name: "Estocada con press de hombro unilateral", level: "Intermedio" },
                { name: "Peso muerto con cargada unilateral y press de hombro", level: "Avanzado" },
                { name: "Puente glúteo unilateral con press de pecho alternado", level: "Intermedio" },
                { name: "Peso muerto unipodal + Press de hombros potente", level: "Avanzado" },
                { name: "Peso muerto unipodal + Bíceps", level: "Intermedio" },
                { name: "Press en piso más puente glúteo (press pecho explosivo)", level: "Avanzado" }
            ]}
          ]
        };

        async function init() {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
                onAuthStateChanged(auth, (u) => {
                    if (u) { state.user = u; setupSync(); startTimer(); }
                    render();
                });
            } catch (error) { console.error("Fallo en inicialización:", error); }
        }

        function setupSync() {
            if (!state.user) return;
            onSnapshot(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'master_html'), (s) => {
                if (s.exists()) state.catalog = s.data();
                else setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'master_html'), INITIAL_CATALOG);
                render();
            }, (e) => console.error("Catálogo:", e));
            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'patients'), (s) => {
                state.patients = s.docs.map(d => ({ id: d.id, ...d.data() }));
                render();
            }, (e) => console.error("Pacientes:", e));
            onSnapshot(collection(db, 'artifacts', appId, 'public', 'data', 'history'), (s) => {
                state.history = s.docs.map(d => ({ id: d.id, ...d.data() })).sort((a,b) => b.ts - a.ts);
                render();
            }, (e) => console.error("Historial:", e));
            onSnapshot(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'sessions_html'), (s) => {
                if (s.exists()) {
                    const remoteSlots = s.data().slots;
                    if (!state.slots.some(sl => sl.isActive)) state.slots = remoteSlots;
                } else {
                    setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'sessions_html'), { slots: state.slots });
                }
                render();
            }, (e) => console.error("Sesiones:", e));
        }

        function startTimer() {
            setInterval(() => {
                let changed = false;
                state.slots.forEach(s => { if (s.isActive) { s.time++; changed = true; } });
                if (changed) render();
            }, 1000);
            setInterval(async () => {
                if (!state.user) return;
                toggleSyncing(true);
                try { await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'sessions_html'), { slots: state.slots }); }
                catch (e) { console.error("Auto-guardado:", e); }
                toggleSyncing(false);
            }, 5000);
        }

        function render() {
            const main = document.getElementById('mainContent');
            if (!main) return;
            if (!state.user) {
                main.innerHTML = `<div class="flex items-center justify-center h-64 text-slate-400 font-bold">Autenticando...</div>`;
                return;
            }
            document.querySelectorAll('.nav-btn').forEach(btn => {
                const id = btn.id.replace('nav-', '');
                btn.className = `nav-btn flex flex-col items-center gap-1.5 px-5 py-1 transition-all ${state.view === id ? 'text-blue-600' : 'text-slate-300'}`;
            });
            if (state.view === 'workout') renderWorkout(main);
            else if (state.view === 'patients') renderPatients(main);
            else if (state.view === 'catalog') renderCatalog(main);
            else if (state.view === 'history') renderHistory(main);
            lucide.createIcons();
        }

        window.setView = (v) => { state.view = v; render(); };

        function renderWorkout(container) {
            const current = state.slots[state.activeIdx];
            const mobility = state.catalog.categories[0] || { exercises: [] };
            container.innerHTML = `
                <div class="space-y-6">
                    <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
                        ${state.slots.map((s, i) => `
                            <button onclick="setActiveSlot(${i})" class="px-4 py-3 rounded-2xl font-bold text-[11px] transition-all flex flex-col items-center min-w-[100px] border ${state.activeIdx === i ? 'bg-blue-600 border-blue-600 text-white shadow-lg shadow-blue-100' : 'bg-white border-slate-100 text-slate-400'}">
                                <span class="truncate w-full text-center">${s.patientName ? s.patientName.split(' ')[0] : 'Slot ' + s.id}</span>
                                <span class="text-[9px] opacity-70 font-mono tracking-wider">${formatTime(s.time)}</span>
                            </button>
                        `).join('')}
                    </div>
                    <div class="bg-white p-6 rounded-[2.5rem] shadow-xl shadow-slate-200/40 border border-slate-100 space-y-6">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="p-4 rounded-2xl transition-all ${current.isActive ? 'bg-blue-50 ring-2 ring-blue-100' : 'bg-slate-50'}">
                                    <i data-lucide="timer" class="w-8 h-8 ${current.isActive ? 'text-blue-600' : 'text-slate-300'}"></i>
                                </div>
                                <div>
                                    <p class="text-4xl font-mono font-black tracking-tight text-slate-800">${formatTime(current.time)}</p>
                                    <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest opacity-50">Sesión R${current.id}</p>
                                </div>
                            </div>
                            <button onclick="toggleSlotTimer()" class="p-5 rounded-full shadow-lg transition-all active:scale-90 ${current.isActive ? 'bg-rose-500 text-white shadow-rose-200' : 'bg-blue-600 text-white shadow-blue-200'}">
                                <i data-lucide="${current.isActive ? 'pause' : 'play'}" class="${!current.isActive ? 'ml-1' : ''}"></i>
                            </button>
                        </div>
                        <div class="relative group">
                            <i data-lucide="user" class="absolute left-4 top-4 text-slate-300"></i>
                            <input oninput="updatePatientName(this.value)" class="w-full bg-slate-50 border border-slate-100 p-4 pl-12 rounded-2xl outline-none focus:ring-4 ring-blue-50 transition-all font-bold text-slate-700 placeholder:text-slate-300" placeholder="Nombre del paciente..." value="${current.patientName || ''}">
                        </div>
                    </div>
                    <div class="space-y-8">
                        <div class="space-y-3">
                            <button onclick="toggleMobility()" class="w-full flex justify-between items-center px-4 py-2 hover:bg-slate-100 rounded-xl transition-colors">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Movilidad (Predeterminado)</p>
                                <i data-lucide="${current.mobilityCollapsed ? 'chevron-down' : 'chevron-up'}" class="w-4 h-4 text-slate-400"></i>
                            </button>
                            ${!current.mobilityCollapsed ? `<div class="space-y-2">${mobility.exercises.map((ex, i) => renderExerciseRow(i + 1, ex.name, !!current.completed[ex.name], 'Mobility', i, true)).join('')}</div>` : ''}
                        </div>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center px-4">
                                <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest">Fuerza / Integración</p>
                                <button onclick="openPicker()" class="bg-blue-50 text-blue-600 px-4 py-2 rounded-xl text-[10px] font-black hover:bg-blue-600 hover:text-white transition-all shadow-sm">+ BIBLIOTECA</button>
                            </div>
                            ${current.strength.map((ex, i) => renderExerciseRow(i + 1, ex.name, !!current.completed[ex.name], ex.reps, i, false)).join('')}
                            ${current.strength.length === 0 ? '<p class="text-center py-10 text-slate-300 text-xs italic">Añade ejercicios de fuerza.</p>' : ''}
                        </div>
                    </div>
                    <button onclick="finishSession()" class="w-full bg-blue-600 text-white py-6 rounded-[2rem] font-black shadow-xl shadow-blue-100 active:scale-95 transition-all text-lg mt-4 mb-10 border-b-4 border-blue-700">GUARDAR SESIÓN FINALIZADA</button>
                </div>`;
        }

        function renderExerciseRow(num, name, checked, reps, idx, isMobility) {
            return `<div class="group relative flex items-center gap-4 p-5 rounded-3xl border transition-all duration-300 ${checked ? 'emerald-card shadow-lg shadow-emerald-100 scale-[0.98]' : 'bg-white border-slate-100 shadow-sm hover:border-blue-100'}">
                <button onclick="toggleExerciseCheck('${name.replace(/'/g, "\\'")}')" class="shrink-0 transition-transform active:scale-75 ${checked ? 'text-white' : 'text-slate-200 hover:text-blue-400'}">
                    <i data-lucide="${checked ? 'check-circle-2' : 'circle'}" class="w-7 h-7"></i>
                </button>
                <div class="flex-1 min-w-0 text-left">
                    <div class="flex items-center gap-2">
                        <span class="text-[10px] font-black ${checked ? 'text-emerald-100' : 'text-slate-300'}">${num}.</span>
                        <p class="text-sm font-black truncate leading-tight">${name}</p>
                    </div>
                    <input onchange="updateExerciseReps(${idx}, this.value, ${isMobility})" class="bg-transparent text-[11px] font-black uppercase tracking-widest outline-none border-b border-transparent focus:border-white w-full ${checked ? 'text-emerald-100 placeholder:text-emerald-200' : 'text-slate-400'}" value="${reps}" placeholder="Dosis...">
                </div>
                ${!isMobility && !checked ? `<button onclick="removeExercise(${idx})" class="p-2 text-slate-200 hover:text-rose-500 opacity-0 group-hover:opacity-100 transition-all"><i data-lucide="trash-2" class="w-4 h-4"></i></button>` : ''}
            </div>`;
        }

        function renderPatients(container) {
            container.innerHTML = `<div class="space-y-6">
                <div class="flex justify-between items-center">
                    <h2 class="text-2xl font-black text-slate-800">Fichas Clínicas</h2>
                    <button onclick="openEditPatient()" class="bg-blue-600 text-white p-3 rounded-xl shadow-lg"><i data-lucide="user-plus"></i></button>
                </div>
                <div class="grid gap-3">
                    ${state.patients.map(p => `
                        <div class="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm flex items-center justify-between group hover:border-blue-200 transition-all">
                            <div class="flex items-center gap-4 flex-1">
                                <div class="p-3 bg-blue-50 text-blue-600 rounded-2xl"><i data-lucide="user-circle" class="w-7 h-7"></i></div>
                                <div>
                                    <h4 class="font-bold text-slate-800 leading-none">${p.name}</h4>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase mt-1 tracking-wider">${p.age || "?"} AÑOS</p>
                                </div>
                            </div>
                            <div class="flex gap-1">
                                <button onclick="viewPatientLog('${p.id}')" class="p-3 text-slate-300 hover:text-blue-500 transition-colors"><i data-lucide="calendar"></i></button>
                                <button onclick="openEditPatient('${p.id}')" class="p-3 text-slate-300 hover:text-blue-500 transition-colors"><i data-lucide="file-text"></i></button>
                                <button onclick="deletePatient('${p.id}', '${p.name.replace(/'/g, "\\'")}')" class="p-3 text-slate-300 hover:text-rose-500 transition-colors"><i data-lucide="trash-2"></i></button>
                            </div>
                        </div>`).join('')}
                </div></div>`;
        }

        function renderCatalog(container) {
            const search = (state.search.library || '').toLowerCase();
            const filtered = state.catalog.categories.map(cat => {
                const exercises = (cat.exercises || []).filter(ex => ex.name.toLowerCase().includes(search));
                return (cat.name.toLowerCase().includes(search) || exercises.length > 0) ? {...cat, exercises: exercises.length > 0 ? exercises : cat.exercises} : null;
            }).filter(Boolean);
            container.innerHTML = `<div class="space-y-8 text-left">
                <header class="flex justify-between items-center mb-2">
                    <h2 class="text-2xl font-black text-slate-800">Biblioteca Clínica</h2>
                    <i data-lucide="layers" class="text-blue-600"></i>
                </header>
                <div class="relative group mb-6">
                    <i data-lucide="search" class="absolute left-4 top-4 text-slate-300 group-focus-within:text-blue-600 transition-colors w-5 h-5"></i>
                    <input oninput="updateLibrarySearch(this.value)" class="w-full bg-white border border-slate-200 p-4 pl-12 rounded-2xl outline-none focus:ring-4 ring-blue-50 transition-all font-bold text-slate-700 shadow-sm" placeholder="Buscar ejercicio o categoría..." value="${state.search.library}">
                </div>
                ${filtered.map((cat, catIdx) => `
                    <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm space-y-4">
                        <div class="flex justify-between items-center border-b border-slate-50 pb-3 text-left">
                            <div class="flex items-center gap-3 flex-1">
                                <div class="flex flex-col">
                                    <button onclick="moveCat(${catIdx}, -1)" class="text-slate-200 hover:text-blue-500"><i data-lucide="arrow-up" class="w-4 h-4"></i></button>
                                    <button onclick="moveCat(${catIdx}, 1)" class="text-slate-200 hover:text-blue-500"><i data-lucide="arrow-down" class="w-4 h-4"></i></button>
                                </div>
                                <input onchange="renameCat(${catIdx}, this.value)" class="bg-transparent font-black text-blue-600 uppercase tracking-widest text-[11px] outline-none w-full border-b border-transparent focus:border-blue-100" value="${cat.name}">
                            </div>
                            <button onclick="deleteCat(${catIdx})" class="text-slate-200 hover:text-rose-500 p-1"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                        </div>
                        <div class="flex flex-col gap-2">
                            ${cat.exercises.map((ex, i) => `
                                <div class="group bg-slate-50/50 p-4 rounded-2xl border border-slate-100 flex items-center justify-between hover:bg-white transition-all shadow-sm">
                                    <div class="flex flex-col gap-1 flex-1">
                                        <div class="flex items-center gap-2">
                                            <span class="text-[10px] font-black text-slate-300">${i + 1}.</span>
                                            <input onchange="renameEx(${catIdx}, ${i}, this.value)" class="text-sm font-bold text-slate-600 bg-transparent outline-none flex-1 focus:text-blue-600" value="${ex.name}">
                                        </div>
                                        <button onclick="toggleLevel(${catIdx}, ${i})" class="ml-5 px-2 py-0.5 rounded-full text-[8px] font-black uppercase tracking-tighter transition-all ${getLevelColor(ex.level)} border border-current opacity-70 w-max">${ex.level}</button>
                                    </div>
                                    <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-all">
                                        <button onclick="moveEx(${catIdx}, ${i}, -1)" class="p-1 text-slate-300 hover:text-blue-500"><i data-lucide="arrow-up" class="w-4 h-4"></i></button>
                                        <button onclick="removeExFromCat(${catIdx}, ${i})" class="p-1 text-slate-300 hover:text-rose-500"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                    </div>
                                </div>`).join('')}
                            <div class="flex gap-2 p-1 mt-2 border-2 border-dashed border-blue-50 rounded-2xl">
                                <input id="newEx_${catIdx}" placeholder="Añadir ejercicio..." class="flex-1 bg-transparent p-3 text-xs font-bold text-slate-500 outline-none">
                                <button onclick="addExToCat(${catIdx})" class="bg-blue-600 text-white p-3 rounded-xl shadow-md active:scale-95 transition-transform"><i data-lucide="plus" class="w-5 h-5"></i></button>
                            </div>
                        </div>
                    </div>`).join('')}
                <div class="p-8 bg-white border-4 border-dashed border-slate-100 rounded-[2.5rem] flex flex-col items-center gap-4">
                    <p class="text-xs font-black text-slate-400 uppercase tracking-widest text-center">Nueva Categoría</p>
                    <div class="flex w-full gap-2">
                        <input id="newCatNameInput" class="flex-1 bg-slate-50 p-4 rounded-2xl border border-slate-100 outline-none font-bold text-slate-700 shadow-inner" placeholder="Ej: TRACCIÓN">
                        <button onclick="addCategory()" class="bg-blue-600 text-white p-4 rounded-2xl shadow-lg active:scale-95"><i data-lucide="save"></i></button>
                    </div>
                </div></div>`;
        }

        function renderHistory(container) {
            container.innerHTML = `<div class="space-y-4 text-left">
                <h2 class="text-2xl font-black text-slate-800">Historial Global</h2>
                ${state.history.map(h => `
                    <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm relative overflow-hidden group">
                        <div class="absolute top-0 right-0 p-3 bg-blue-50 text-blue-600 font-mono text-xs font-bold rounded-bl-xl">${formatTime(h.time)}</div>
                        <div class="flex justify-between items-center pr-14 mb-1">
                            <h4 class="font-black text-slate-800 text-lg">${h.patientName}</h4>
                            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition-all">
                                <button onclick="openEditHistory('${h.id}')" class="p-2 text-slate-300 hover:text-blue-500"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
                                <button onclick="deleteLog('${h.id}')" class="p-2 text-slate-300 hover:text-rose-500"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                            </div>
                        </div>
                        <p class="text-[9px] text-slate-300 font-bold mb-4 uppercase flex items-center gap-1"><i data-lucide="calendar" class="w-3 h-3"></i> ${new Date(h.ts).toLocaleString()}</p>
                        <div class="flex flex-wrap gap-1.5">
                            ${(h.exercises || []).map(ex => `<span class="px-3 py-1 bg-slate-50 text-[10px] font-bold text-slate-500 rounded-lg border border-slate-100">${ex}</span>`).join('')}
                        </div>
                    </div>`).join('')}
            </div>`;
        }

        const formatTime = (s) => `${Math.floor((s||0)/60)}:${((s||0)%60).toString().padStart(2, '0')}`;
        const getLevelColor = (l) => l === "Principiante" ? "bg-emerald-50 text-emerald-600" : (l === "Intermedio" ? "bg-amber-50 text-amber-600" : "bg-rose-50 text-rose-600");
        const toggleSyncing = (val) => {
            state.syncing = val;
            const indicator = document.getElementById('syncIndicator');
            const icon = document.getElementById('cloudIcon');
            if (indicator) indicator.style.opacity = val ? '1' : '0.5';
            if (icon) icon.className = val ? 'w-4 h-4 text-blue-500 animate-pulse' : 'w-4 h-4 text-emerald-500';
        };

        window.setActiveSlot = (i) => { state.activeIdx = i; render(); };
        window.toggleSlotTimer = () => { state.slots[state.activeIdx].isActive = !state.slots[state.activeIdx].isActive; render(); };
        window.updatePatientName = (v) => { state.slots[state.activeIdx].patientName = v; render(); };
        window.toggleMobility = () => { state.slots[state.activeIdx].mobilityCollapsed = !state.slots[state.activeIdx].mobilityCollapsed; render(); };
        window.toggleExerciseCheck = (name) => { const c = state.slots[state.activeIdx]; c.completed[name] = !c.completed[name]; render(); };
        window.updateExerciseReps = (idx, val, isMobility) => { if (!isMobility) state.slots[state.activeIdx].strength[idx].reps = val; };
        window.removeExercise = (idx) => { state.slots[state.activeIdx].strength.splice(idx, 1); render(); };
        window.updateLibrarySearch = (v) => { state.search.library = v; render(); };

        window.openPicker = () => {
            document.getElementById('modalContainer').classList.remove('hidden');
            renderPicker();
        };

        function renderPicker() {
            const search = (state.search.picker || '').toLowerCase();
            const modal = document.getElementById('modalContainer');
            const current = state.slots[state.activeIdx];
            modal.innerHTML = `<div class="bg-white w-full max-w-xl rounded-[2.5rem] p-8 max-h-[85vh] flex flex-col shadow-2xl text-left">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-2xl font-black text-slate-800 italic">Elegir Ejercicios</h3>
                    <button onclick="closeModal()" class="p-2 bg-slate-100 rounded-full text-slate-400"><i data-lucide="x"></i></button>
                </div>
                <div class="relative group mb-6">
                    <i data-lucide="search" class="absolute left-4 top-3 text-slate-300 w-5 h-5"></i>
                    <input id="pickerSearchInput" oninput="updatePickerSearch(this.value)" class="w-full bg-slate-50 border border-slate-100 p-3 pl-10 rounded-xl outline-none focus:ring-4 ring-blue-50 transition-all font-bold text-slate-600" placeholder="Filtrar por nombre..." value="${state.search.picker || ''}">
                </div>
                <div class="overflow-y-auto pr-2 space-y-8 flex-1 scrollbar-hide">
                    ${state.catalog.categories.slice(1).map(cat => {
                        const filteredExs = cat.exercises.filter(ex => ex.name.toLowerCase().includes(search));
                        if (!cat.name.toLowerCase().includes(search) && filteredExs.length === 0) return '';
                        return `<div class="space-y-3">
                            <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest ml-2">${cat.name}</p>
                            <div class="grid gap-2">
                                ${filteredExs.map(ex => {
                                    const isSelected = !!current.strength.find(s => s.name === ex.name);
                                    return `<button onclick="pickerToggle('${ex.name.replace(/'/g, "\\'")}')" class="text-left p-4 rounded-2xl text-sm font-bold transition-all border ${isSelected ? 'bg-blue-600 border-blue-600 text-white shadow-lg' : 'bg-slate-50 border-transparent text-slate-500 hover:bg-white'}">
                                        <div class="flex items-center gap-3">
                                            <i data-lucide="${isSelected ? 'check-circle-2' : 'circle'}" class="w-5 h-5"></i>
                                            <div class="flex flex-col">
                                                <span>${ex.name}</span>
                                                <span class="text-[8px] uppercase tracking-tighter opacity-70">${ex.level}</span>
                                            </div>
                                        </div>
                                    </button>`;
                                }).join('')}
                            </div>
                        </div>`;
                    }).join('')}
                </div>
                <button onclick="closeModal()" class="w-full mt-6 bg-blue-600 text-white py-5 rounded-[2rem] font-black shadow-lg active:scale-95">CONFIRMAR</button>
            </div>`;
            lucide.createIcons();
            const searchInput = document.getElementById('pickerSearchInput');
            if (searchInput) searchInput.focus();
        }

        window.updatePickerSearch = (v) => { state.search.picker = v; renderPicker(); };
        window.pickerToggle = (name) => {
            const current = state.slots[state.activeIdx];
            const exists = current.strength.findIndex(s => s.name === name);
            if (exists >= 0) current.strength.splice(exists, 1);
            else current.strength.push({ name, reps: "3x12" });
            renderPicker(); render();
        };
        window.closeModal = () => {
            document.getElementById('modalContainer').classList.add('hidden');
            state.search.picker = ''; state.isEditingPatient = null; state.isViewingHistory = null; state.isEditingHistory = null;
            render();
        };

        window.finishSession = async () => {
            if (!state.user) return;
            const current = state.slots[state.activeIdx];
            if (!current.patientName) return alert("Ingresa el nombre.");
            toggleSyncing(true);
            const name = current.patientName.trim();
            if (!state.patients.find(p => p.name.toLowerCase() === name.toLowerCase())) {
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'patients'), { name, age: "", history: "Paciente automático.", ts: Date.now() });
            }
            const log = {
                patientName: name,
                time: current.time,
                exercises: [...state.catalog.categories[0].exercises.map(ex => ({name: ex.name})), ...current.strength].filter(ex => current.completed[ex.name]).map(ex => ex.name),
                ts: Date.now()
            };
            await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'history'), log);
            state.slots[state.activeIdx] = { id: current.id, patientName: "", strength: [], time: 0, isActive: false, completed: {}, mobilityCollapsed: true };
            await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'sessions_html'), { slots: state.slots });
            state.view = 'history'; render(); toggleSyncing(false);
        };

        window.renameCat = async (idx, val) => { if (!state.user) return; state.catalog.categories[idx].name = val; await saveCatalog(state.catalog); };
        window.deleteCat = async (idx) => { if (!state.user || !confirm("¿Borrar categoría?")) return; state.catalog.categories.splice(idx, 1); await saveCatalog(state.catalog); };
        window.renameEx = async (catIdx, exIdx, val) => { if (!state.user) return; state.catalog.categories[catIdx].exercises[exIdx].name = val; await saveCatalog(state.catalog); };
        window.toggleLevel = async (catIdx, exIdx) => {
            if (!state.user) return;
            const lvls = ["Principiante", "Intermedio", "Avanzado"];
            const current = state.catalog.categories[catIdx].exercises[exIdx].level;
            state.catalog.categories[catIdx].exercises[exIdx].level = lvls[(lvls.indexOf(current) + 1) % 3];
            await saveCatalog(state.catalog);
        };
        window.moveCat = async (idx, dir) => {
            if (!state.user) return;
            if (dir === -1 && idx === 0) return;
            if (dir === 1 && idx === state.catalog.categories.length - 1) return;
            const cats = state.catalog.categories;
            [cats[idx], cats[idx + dir]] = [cats[idx + dir], cats[idx]];
            await saveCatalog(state.catalog);
        };
        window.moveEx = async (catIdx, exIdx, dir) => {
            if (!state.user) return;
            if (dir === -1 && exIdx === 0) return;
            if (dir === 1 && exIdx === state.catalog.categories[catIdx].exercises.length - 1) return;
            const items = state.catalog.categories[catIdx].exercises;
            [items[exIdx], items[exIdx + dir]] = [items[exIdx + dir], items[exIdx]];
            await saveCatalog(state.catalog);
        };
        window.removeExFromCat = async (catIdx, exIdx) => { if (!state.user) return; state.catalog.categories[catIdx].exercises.splice(exIdx, 1); await saveCatalog(state.catalog); };
        window.addExToCat = async (idx) => {
            if (!state.user) return;
            const input = document.getElementById('newEx_' + idx);
            const name = input.value;
            if (!name) return;
            state.catalog.categories[idx].exercises.push({ name, level: "Intermedio" });
            await saveCatalog(state.catalog);
            input.value = "";
        };
        window.addCategory = async () => {
            if (!state.user) return;
            const input = document.getElementById('newCatNameInput');
            const name = input.value;
            if (!name) return;
            state.catalog.categories.push({ id: Date.now().toString(), name: name.toUpperCase(), exercises: [] });
            await saveCatalog(state.catalog);
            input.value = "";
        };
        async function saveCatalog(cat) {
            if (!state.user) return;
            toggleSyncing(true);
            try { await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'config', 'master_html'), cat); }
            catch(e) { console.error(e); }
            toggleSyncing(false); render();
        }

        window.deletePatient = async (id, name) => { if (confirm(`¿Borrar ficha de ${name}?`)) await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'patients', id)); };
        window.deleteLog = async (id) => { if (confirm("¿Borrar log?")) await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'history', id)); };

        window.openEditPatient = (id = null) => {
            const modal = document.getElementById('modalContainer');
            const p = id ? state.patients.find(x => x.id === id) : { name: '', age: '', history: '' };
            state.isEditingPatient = { ...p, id };
            modal.innerHTML = `<div class="bg-white w-full max-w-xl rounded-[2.5rem] p-8 shadow-2xl space-y-6 text-left">
                <h3 class="text-xl font-black text-slate-800">${id ? 'Editar Ficha' : 'Nueva Ficha'}</h3>
                <div class="space-y-4">
                    <input id="editPName" class="w-full bg-slate-50 p-4 rounded-2xl border border-slate-100 outline-none font-bold text-slate-700" placeholder="Nombre" value="${p.name}">
                    <input id="editPAge" type="number" class="w-full bg-slate-50 p-4 rounded-2xl border border-slate-100 outline-none font-bold text-slate-700" placeholder="Edad" value="${p.age}">
                    <textarea id="editPHistory" class="w-full bg-slate-50 p-4 rounded-2xl border border-slate-100 outline-none font-bold text-slate-700 h-40" placeholder="Notas...">${p.history}</textarea>
                </div>
                <div class="flex gap-3">
                    <button onclick="closeModal()" class="flex-1 bg-slate-100 py-4 rounded-2xl font-bold text-slate-500">Cerrar</button>
                    <button onclick="savePatient()" class="flex-1 bg-blue-600 py-4 rounded-2xl font-bold text-white shadow-lg">Guardar</button>
                </div>
            </div>`;
            modal.classList.remove('hidden');
        };

        window.savePatient = async () => {
            const id = state.isEditingPatient.id;
            const name = document.getElementById('editPName').value;
            const age = document.getElementById('editPAge').value;
            const historyText = document.getElementById('editPHistory').value;
            if (id) await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'patients', id), { name, age, history: historyText });
            else await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'patients'), { name, age, history: historyText, ts: Date.now() });
            closeModal();
        };

        window.viewPatientLog = (id) => {
            const modal = document.getElementById('modalContainer');
            const p = state.patients.find(x => x.id === id);
            const pLogs = state.history.filter(h => h.patientName.toLowerCase() === p.name.toLowerCase());
            modal.innerHTML = `<div class="bg-white w-full max-w-xl rounded-[2.5rem] p-8 shadow-2xl flex flex-col max-h-[85vh] text-left">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h3 class="text-2xl font-black text-slate-800">Expediente</h3>
                        <p class="text-blue-600 font-bold">${p.name}</p>
                    </div>
                    <button onclick="closeModal()" class="p-3 bg-slate-100 rounded-full"><i data-lucide="x"></i></button>
                </div>
                <div class="overflow-y-auto pr-2 space-y-4">
                    ${pLogs.length === 0 ? '<p class="text-slate-400 italic">Sin registros.</p>' : pLogs.map(h => `
                        <div class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">${new Date(h.ts).toLocaleString()}</p>
                            <div class="flex flex-wrap gap-1.5">${(h.exercises || []).map(ex => `<span class="text-[9px] px-2 py-1 bg-white border border-slate-100 rounded-md font-bold">${ex}</span>`).join('')}</div>
                        </div>`).join('')}
                </div>
            </div>`;
            modal.classList.remove('hidden');
            lucide.createIcons();
        };

        window.openEditHistory = (id) => {
            const h = state.history.find(x => x.id === id);
            state.isEditingHistory = { ...h };
            const modal = document.getElementById('modalContainer');
            modal.innerHTML = `<div class="bg-white w-full max-w-xl rounded-[2.5rem] p-8 shadow-2xl space-y-6 text-left">
                <h3 class="text-xl font-black text-slate-800">Editar Log</h3>
                <div class="space-y-4">
                    <input id="editHName" class="w-full bg-slate-50 p-4 rounded-2xl border border-slate-100 outline-none font-bold text-slate-700" value="${h.patientName}">
                    <textarea id="editHExs" class="w-full bg-slate-50 p-4 rounded-2xl border border-slate-100 outline-none font-bold text-slate-700 h-40" placeholder="Ejercicios (separados por coma)">${h.exercises.join(', ')}</textarea>
                </div>
                <div class="flex gap-3">
                    <button onclick="closeModal()" class="flex-1 bg-slate-100 py-4 rounded-2xl font-bold text-slate-500">Cerrar</button>
                    <button onclick="saveHistoryEdit('${id}')" class="flex-1 bg-blue-600 py-4 rounded-2xl font-bold text-white shadow-lg">Actualizar</button>
                </div>
            </div>`;
            modal.classList.remove('hidden');
        };

        window.saveHistoryEdit = async (id) => {
            const patientName = document.getElementById('editHName').value;
            const exercises = document.getElementById('editHExs').value.split(',').map(s => s.trim());
            await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'history', id), { patientName, exercises });
            closeModal();
        };

        init();
    </script>
</body>
</html>
